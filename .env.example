# SEC asks automated clients to identify a name and contact email.
SEC_USER_AGENT=Your Name your-email@example.com

# Optional Cloudflare R2 credentials. Runtime YAML stores only these env names.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional human-readable publisher recorded in immutable manifests.
STQ_PUBLISHED_BY=

# Live Toss execution (not used by backtest/research data ingestion).
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_ACCOUNT_SEQ=1
