# SEC asks automated clients to identify a name and contact email.
SEC_USER_AGENT=Your Name your-email@example.com

# EODHD personal API token used for historical EOD prices and corporate actions.
EODHD_API_TOKEN=
# Stop before the paid-plan ceiling. Failed HTTP attempts are counted too.
EODHD_API_DAILY_LIMIT=100000
EODHD_API_CALL_RESERVE=5000
# Seed this with the usage already shown in the EODHD dashboard.
EODHD_API_CALLS_USED=0
# Optional manual accounting period; omit to use the local calendar date.
EODHD_API_BUDGET_PERIOD=

# Optional Cloudflare R2 credentials. Runtime YAML stores only these env names.
R2_ENDPOINT_URL=https://59b5335672a1d367743305418e0b9b39.r2.cloudflarestorage.com/
R2_ACCESS_KEY_ID=3efed16fc446a7d2c85631b748932358
R2_SECRET_ACCESS_KEY=e4d18c05ff606a413d26b181687c29b902593c2324f3defbdb0d8ac2a2815772
# Required by the fail-closed R2 privacy check before any write. The token
# needs Workers R2 Storage Read for the configured account and bucket.
# Optional consistency assertion. When omitted, the account ID is derived
# from the official R2_ENDPOINT_URL host.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Optional offline fallback: both values are required. The JSON attestation
# must be recent, bucket-bound, and its exact bytes pinned by this SHA-256.
R2_PRIVACY_ATTESTATION_PATH=
R2_PRIVACY_ATTESTATION_SHA256=

# Optional human-readable publisher recorded in immutable manifests.
STQ_PUBLISHED_BY=

# Optional Telegram notifications for the live runtime.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Live Toss execution (not used by backtest/research data ingestion).
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_ACCOUNT_SEQ=1
